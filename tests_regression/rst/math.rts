[STYLESHEET]
base = sphinx_base14


[default:Paragraph]
font_size = 12pt

[math block paragraph]
font_color = #F00

[large inline equation : Equation(has_class='large', inline=True)]
font_size = 14pt
font_color = #0000FF

[large equation : +DisplayEquation(has_class='large') / ... / Equation]
font_size = 20pt
